# ============================================
# SUI NETWORK CONFIGURATION
# ============================================
SUI_NETWORK=localnet

# Custom RPC URL (optional, defaults to public endpoints)
# SUI_RPC_URL=https://fullnode.devnet.sui.io:443
# For localnet in Docker, use: http://host.docker.internal:9000 (Mac/Windows)
# For localnet in Docker on Linux, use: http://172.17.0.1:9000 (or your host IP)

# ============================================
# DEPLOYMENT CONFIGURATION
# ============================================
GAS_BUDGET=100000000
ADMIN_ADDRESS=
MNEMONIC=
KEY_SCHEME=ed25519

# ============================================
# TYPESCRIPT EXAMPLES CONFIGURATION
# ============================================
# Required for running TypeScript examples
# PRIVATE_KEY is used for admin/server operations (creating objects)
PRIVATE_KEY=


# Simulate as a player
# PLAYER_A_ADDRESS is the address to transfer OwnerCaps to
# PLAYER_A_PRIVATE_KEY is the private key for the player to use OwnerCaps
PLAYER_A_ADDRESS=
PLAYER_A_PRIVATE_KEY=